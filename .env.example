# ─────────────────────────────────────────────────────────────────
# SafeRoute — Women Safety Navigation Agent
# Copy this file to .env and fill in your values.
# The app runs in demo/simulation mode for any key left blank.
# ─────────────────────────────────────────────────────────────────

# Google Gemini API  (free tier — get key at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio SMS alerts  (free trial at https://www.twilio.com/try-twilio)
# Leave all three blank to use simulated alerts (no SMS sent)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx   # your Twilio sender number
